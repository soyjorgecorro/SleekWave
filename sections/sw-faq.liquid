<div class="sw-faq color-{{ section.settings.color_scheme }}">
  <div class="sw-faq__inner page-width">
    {% if section.settings.heading != blank %}
      <h2 class="sw-faq__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="sw-faq__list">

      {% for i in (1..5) %}
        {% liquid
          assign q_key = 'q_' | append: i
          assign a_key = 'a_' | append: i
          assign q_val = section.settings[q_key]
          assign a_val = section.settings[a_key]
        %}
        {% if q_val != blank and a_val != blank %}
          <details class="sw-faq__item">
            <summary class="sw-faq__question">
              <span>{{ q_val }}</span>
              <span class="sw-faq__chevron" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </span>
            </summary>
            <div class="sw-faq__answer">
              <p>{{ a_val }}</p>
            </div>
          </details>
        {% endif %}
      {% endfor %}

    </div>
  </div>
</div>

{% stylesheet %}
  .sw-faq {
    padding-block: 72px;
    background: #FAF8F5;
  }

  .sw-faq__heading {
    text-align: center;
    font-family: var(--font-heading--family);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 48px;
    color: #0D0D0D;
  }

  .sw-faq__list {
    max-width: 720px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sw-faq__item {
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }

  .sw-faq__item:first-child {
    border-top: 1px solid rgba(0,0,0,0.1);
  }

  .sw-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-block: 20px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-body--family);
    font-size: 1rem;
    font-weight: 500;
    color: #0D0D0D;
    user-select: none;
  }

  .sw-faq__question::-webkit-details-marker {
    display: none;
  }

  .sw-faq__chevron {
    flex-shrink: 0;
    color: #C9A96E;
    transition: transform 0.25s ease;
  }

  details[open] .sw-faq__chevron {
    transform: rotate(180deg);
  }

  .sw-faq__answer {
    padding-bottom: 20px;
    padding-right: 40px;
  }

  .sw-faq__answer p {
    font-family: var(--font-body--family);
    font-size: 0.9rem;
    line-height: 1.75;
    color: #5a5a5a;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .sw-faq {
      padding-block: 48px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "header",
      "content": "Question 1"
    },
    {
      "type": "text",
      "id": "q_1",
      "label": "Question",
      "default": "Does it work on thick or curly hair?"
    },
    {
      "type": "textarea",
      "id": "a_1",
      "label": "Answer",
      "default": "Yes. The 360° airflow barrel and ionic technology are effective on all hair types, including thick, coarse, and naturally curly hair. We recommend using the medium or high heat setting for denser textures."
    },
    {
      "type": "header",
      "content": "Question 2"
    },
    {
      "type": "text",
      "id": "q_2",
      "label": "Question",
      "default": "How long does it take to heat up?"
    },
    {
      "type": "textarea",
      "id": "a_2",
      "label": "Answer",
      "default": "The SleekWave brush reaches full operating temperature in under 60 seconds, so you can go from off to styling in no time."
    },
    {
      "type": "header",
      "content": "Question 3"
    },
    {
      "type": "text",
      "id": "q_3",
      "label": "Question",
      "default": "Is it safe to use daily?"
    },
    {
      "type": "textarea",
      "id": "a_3",
      "label": "Answer",
      "default": "Yes. The ceramic-tourmaline coating distributes heat evenly to prevent hot spots. For best results and long-term hair health, we recommend using a heat protectant spray before styling."
    },
    {
      "type": "header",
      "content": "Question 4"
    },
    {
      "type": "text",
      "id": "q_4",
      "label": "Question",
      "default": "What voltage does it use? Can I use it abroad?"
    },
    {
      "type": "textarea",
      "id": "a_4",
      "label": "Answer",
      "default": "The SleekWave brush is dual voltage (110–240V), making it compatible with outlets worldwide. You may need a plug adapter depending on your destination."
    },
    {
      "type": "header",
      "content": "Question 5"
    },
    {
      "type": "text",
      "id": "q_5",
      "label": "Question",
      "default": "What is the return policy?"
    },
    {
      "type": "textarea",
      "id": "a_5",
      "label": "Answer",
      "default": "We offer a 30-day hassle-free return policy. If you are not completely satisfied, contact our team at support@sleekwave.com and we will take care of you — no questions asked."
    }
  ],
  "presets": [
    {
      "name": "FAQ"
    }
  ]
}
{% endschema %}
