<div class="sw-trust-bar color-{{ section.settings.color_scheme }}">
  <div class="sw-trust-bar__inner page-width">
    <div class="sw-trust-bar__item">
      <span class="sw-trust-bar__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
        </svg>
      </span>
      <span class="sw-trust-bar__text">{{ section.settings.item_1_text }}</span>
    </div>

    <span class="sw-trust-bar__divider" aria-hidden="true"></span>

    <div class="sw-trust-bar__item">
      <span class="sw-trust-bar__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
        </svg>
      </span>
      <span class="sw-trust-bar__text">{{ section.settings.item_2_text }}</span>
    </div>

    <span class="sw-trust-bar__divider" aria-hidden="true"></span>

    <div class="sw-trust-bar__item">
      <span class="sw-trust-bar__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
        </svg>
      </span>
      <span class="sw-trust-bar__text">{{ section.settings.item_3_text }}</span>
    </div>
  </div>
</div>

{% stylesheet %}
  .sw-trust-bar {
    border-top: 1px solid rgba(0,0,0,0.08);
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .sw-trust-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding-block: 16px;
  }

  .sw-trust-bar__item {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    justify-content: center;
    padding-inline: 16px;
  }

  .sw-trust-bar__icon {
    color: #C9A96E;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .sw-trust-bar__text {
    font-size: 0.8rem;
    font-family: var(--font-body--family);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 500;
    white-space: nowrap;
  }

  .sw-trust-bar__divider {
    display: block;
    width: 1px;
    height: 28px;
    background: rgba(0,0,0,0.12);
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .sw-trust-bar__inner {
      flex-direction: column;
      gap: 12px;
      align-items: flex-start;
      padding-inline: 20px;
    }

    .sw-trust-bar__item {
      justify-content: flex-start;
      padding-inline: 0;
    }

    .sw-trust-bar__divider {
      display: none;
    }

    .sw-trust-bar__text {
      white-space: normal;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "item_1_text",
      "label": "Badge 1",
      "default": "30-Day Money Back Guarantee"
    },
    {
      "type": "text",
      "id": "item_2_text",
      "label": "Badge 2",
      "default": "1,200W Professional Grade"
    },
    {
      "type": "text",
      "id": "item_3_text",
      "label": "Badge 3",
      "default": "Free US Shipping Over $50"
    }
  ],
  "presets": [
    {
      "name": "Trust Bar"
    }
  ]
}
{% endschema %}
